# ====================================================================
# PROJECT: mia-iac-agw-glean (REPOSITORY TEMPLATE - SAFE TO PUSH)
# ====================================================================

# --- GCP & Vertex AI Configuration ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
VERTEX_AI_MODEL=gemini-1.5-flash
VERTEX_AI_EMBEDDING_MODEL=text-embedding-004

# --- Azure AD (Entra ID) Identity Integration ---
AZURE_TENANT_ID=your-azure-tenant-guid
AZURE_CLIENT_ID=your-azure-client-app-guid
AZURE_CLIENT_SECRET=your-azure-client-secret-placeholder
AZURE_IDENTITY_PROVIDER_URL=https://login.microsoftonline.com/your-tenant-name

# --- Zero-Trust Transport (mTLS & SSL) ---
MTLS_ENABLED=true
SSL_TRUSTSTORE_LOCATION=/var/private/ssl/kafka.client.truststore.jks
SSL_TRUSTSTORE_PASSWORD=your-truststore-password
SSL_KEYSTORE_LOCATION=/var/private/ssl/kafka.client.keystore.jks
SSL_KEYSTORE_PASSWORD=your-keystore-password
SSL_KEY_PASSWORD=your-private-key-password

# --- Confluent Cloud Event Backbone ---
CONFLUENT_BOOTSTRAP_SERVERS=your-bootstrap-server.confluent.cloud:9092
CONFLUENT_SCHEMA_REGISTRY_URL=https://your-schema-registry.confluent.cloud
CONFLUENT_API_KEY=your-confluent-api-key
CONFLUENT_API_SECRET=your-confluent-api-secret

# --- Glean Target Integration ---
GLEAN_INSTANCE_URL=https://your-instance.glean.com
GLEAN_INDEXING_API_KEY=your-glean-indexing-api-key
GLEAN_APP_ID=your-glean-app-id

# --- Coveo Target Integration ---
COVEO_ORGANIZATION_ID=your-coveo-org-id
COVEO_PUSH_API_KEY=your-coveo-push-api-key

# --- Algolia Target Integration (High-Performance UI) ---
ALGOLIA_APPLICATION_ID=your-algolia-app-id
ALGOLIA_WRITE_API_KEY=your-algolia-write-api-key

# --- SRE, Performance & Audit Tracking ---
COMPLIANCE_STANDARD=NIST-800-53-REV5-ZERO-TRUST
SLO_LATENCY_TARGET_MS=10
SRE_ALERT_CHANNEL=#your-pipeline-alerts-channel
